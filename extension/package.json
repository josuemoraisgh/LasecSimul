{
  "name": "lasecsimul",
  "displayName": "LasecSimul",
  "description": "Simulador de circuitos eletrônicos com MCUs emulados via QEMU, inspirado no SimulIDE.",
  "version": "0.0.1",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lasecsimul.openSchematicEditor",
        "title": "LasecSimul: Open Schematic Editor",
        "icon": "$(go-to-file)",
        "enablement": "!lasecsimul.schematicOpen"
      },
      { "command": "lasecsimul.run", "title": "LasecSimul: Run Simulation" },
      { "command": "lasecsimul.pause", "title": "LasecSimul: Pause Simulation" },
      { "command": "lasecsimul.stop", "title": "LasecSimul: Stop Simulation" },
      { "command": "lasecsimul.palette.addComponent", "title": "LasecSimul: Add Palette Component" },
      {
        "command": "lasecsimul.palette.registerFile",
        "title": "LasecSimul: Registrar Dispositivo ABI/QEMU/Subcircuito",
        "icon": "$(add)"
      },
      {
        "command": "lasecsimul.newSubcircuit",
        "title": "LasecSimul: New Subcircuit",
        "icon": "$(symbol-module)",
        "enablement": "false"
      },
      {
        "command": "lasecsimul.openSettings",
        "title": "LasecSimul: Settings",
        "icon": "$(settings-gear)",
        "enablement": "false"
      },
      {
        "command": "lasecsimul.palette.removeRegistered",
        "title": "LasecSimul: Remover Dispositivo Registrado"
      },
      { "command": "lasecsimul.saveProject", "title": "LasecSimul: Save Project As..." },
      { "command": "lasecsimul.openProject", "title": "LasecSimul: Open Project..." },
      { "command": "lasecsimul.rotateSelectionCw", "title": "LasecSimul: Rotate Selection CW" },
      { "command": "lasecsimul.rotateSelectionCcw", "title": "LasecSimul: Rotate Selection CCW" },
      { "command": "lasecsimul.flipSelectionHorizontal", "title": "LasecSimul: Flip Selection Horizontal" },
      { "command": "lasecsimul.flipSelectionVertical", "title": "LasecSimul: Flip Selection Vertical" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lasecsimul",
          "title": "LasecSimul",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "lasecsimul": [
        {
          "id": "lasecsimul.componentPalette",
          "name": "Components"
        }
      ]
    },
    "configuration": {
      "title": "LasecSimul",
      "properties": {
        "lasecsimul.language": {
          "type": "string",
          "enum": ["system", "pt-BR", "en"],
          "default": "system",
          "description": "Language used by the LasecSimul editor, palette and property sheets."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "lasecsimul.openSchematicEditor",
          "when": "view == lasecsimul.componentPalette",
          "group": "navigation@1"
        },
        {
          "command": "lasecsimul.palette.registerFile",
          "when": "view == lasecsimul.componentPalette",
          "group": "navigation@2"
        },
        {
          "command": "lasecsimul.newSubcircuit",
          "when": "view == lasecsimul.componentPalette",
          "group": "navigation@50"
        },
        {
          "command": "lasecsimul.openSettings",
          "when": "view == lasecsimul.componentPalette",
          "group": "navigation@999"
        }
      ],
      "view/item/context": [
        {
          "command": "lasecsimul.palette.removeRegistered",
          "when": "view == lasecsimul.componentPalette && (viewItem == lasecsimul.palette.component.registered || viewItem == lasecsimul.palette.component.registered.disabled)",
          "group": "inline"
        }
      ]
    },
    "lasecsimul.deviceLibraries": [
      { "libraryManifest": "../devices/library.json" }
    ],
    "keybindings": [
      {
        "command": "lasecsimul.rotateSelectionCw",
        "key": "ctrl+r",
        "when": "activeWebviewPanelId == 'lasecsimul.schematic'"
      },
      {
        "command": "lasecsimul.rotateSelectionCcw",
        "key": "ctrl+shift+r",
        "when": "activeWebviewPanelId == 'lasecsimul.schematic'"
      },
      {
        "command": "lasecsimul.flipSelectionHorizontal",
        "key": "h",
        "when": "activeWebviewPanelId == 'lasecsimul.schematic'"
      },
      {
        "command": "lasecsimul.flipSelectionVertical",
        "key": "v",
        "when": "activeWebviewPanelId == 'lasecsimul.schematic'"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./ && tsc -p ./tsconfig.webview.json",
    "watch": "tsc -p ./ -w",
    "watch:webview": "tsc -p ./tsconfig.webview.json -w",
    "pretest": "npm run compile && tsc -p ./tsconfig.test.json",
    "test": "node out-test/test/project/ProjectSerializer.test.js && node out-test/src/ipc/CoreClient.test.js && node out-test/src/catalog/UnifiedCatalog.test.js && node out-test/src/catalog/catalogMerge.test.js && node out-test/src/language.test.js && node out-test/src/ui/webview/wireGeometry.test.js && node out-test/src/ui/webview/valueFormatting.test.js && node out-test/src/trust/trustDecision.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
