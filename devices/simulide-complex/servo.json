{
  "schemaVersion": 1,
  "typeId": "outputs.servo",
  "name": "Servo Motor",
  "language": "pt-BR",
  "translations": { "en": { "name": "Servo Motor" } },
  "abiVersion": { "major": 3, "minor": 0 },
  "nativeEntry": { "win32-x64": "build/win-x64/device.dll", "linux-x64": "build/linux-x64/device.so", "darwin-universal": "build/macos-universal/device.dylib" },
  "pins": [
    { "id": "pwm", "kind": "DIGITAL_IN", "x": 0, "y": 16, "angle": 180, "length": 8, "label": "PWM" }
