    { "id": "maxPulse", "label": "Pulso maximo", "group": "Principal", "valueKind": "number", "editor": "number", "default": 2000, "min": 1, "step": 10 },
    { "id": "angle", "label": "Angulo", "group": "Leitura", "valueKind": "number", "editor": "display", "default": 90, "readOnly": true }
