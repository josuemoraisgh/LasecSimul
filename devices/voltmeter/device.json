{
  "schemaVersion": 1,
  "typeId": "instruments.voltmeter",
  "name": "Voltímetro DC (medição entre dois pontos)",
  "language": "pt-BR",
  "translations": {
    "en": {
      "name": "DC Voltmeter (two-point measurement)",
      "properties": {
        "displayVoltage": { "label": "Measured voltage", "group": "Reading" }
      }
    }
  },
  "abiVersion": { "major": 3, "minor": 0 },
  "nativeEntry": {
    "win32-x64": "build/win-x64/device.dll",
    "linux-x64": "build/linux-x64/device.so",
    "darwin-universal": "build/macos-universal/device.dylib"
  },
  "package": {
    "width": 50,
    "height": 50,
    "border": true,
    "background": { "kind": "color", "value": "#ffffff" },
    "shapes": [
      { "kind": "text", "x": 18, "y": 28, "value": "V", "fontSize": 20, "color": "#000000" }
    ]
  },
  "pins": [
    { "id": "p1", "kind": "ANALOG_IN", "x": 0, "y": 15, "angle": 180, "length": 8, "label": "+" },
    { "id": "p2", "kind": "ANALOG_IN", "x": 0, "y": 35, "angle": 180, "length": 8, "label": "-" },
    { "id": "outPin", "kind": "ANALOG_OUT", "x": 50, "y": 15, "angle": 0, "length": 8, "label": "out" }
  ],
  "properties": [
    {
      "id": "displayVoltage",
      "label": "Tensão medida",
      "group": "Leitura",
      "valueKind": "number",
      "editor": "display",
      "default": 0,
      "unit": "V",
      "readOnly": true,
      "showOnSymbol": true
    }
  ],
  "buses": [],
  "limits": { "stepTimeoutMs": 4, "expectedComplexity": "low" }
}
