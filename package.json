{
  "name": "lasecsimul-workspace",
  "private": true,
  "version": "0.0.1",
  "description": "Scripts agregados para build/test da Extension (TypeScript) e do Core (C++ nativo) do LasecSimul. Não é o manifest da extensão VSCode -- esse é extension/package.json.",
  "scripts": {
    "build": "node scripts/build-all.js",
    "build:extension": "node scripts/build-extension.js",
    "build:core": "node scripts/build-core.js",
    "build:devices": "node scripts/build-devices.js",
    "watch:extension": "node scripts/build-extension.js --watch",
    "test:core": "node scripts/test-core.js",
    "test:extension": "npm --prefix extension test"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
